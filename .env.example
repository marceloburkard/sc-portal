# Local development (optional — defaults shown)
PORT=8787

# Required on Vercel: create a Blob store in the dashboard (Storage → Blob)
# and connect it to this project. Vercel sets this token automatically.
BLOB_READ_WRITE_TOKEN=

# Match your Blob store type: "public" (default) or "private"
BLOB_ACCESS=public

# Required on Vercel for the daily cron job (/api/cron/refresh).
# Generate a random string and add it in Project Settings → Environment Variables.
CRON_SECRET=
