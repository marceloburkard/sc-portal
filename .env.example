# Local development (optional — defaults shown)
PORT=8787

# Required on Vercel: create a private Blob store in the Vercel dashboard
# (Storage → Blob) and connect it to this project. Vercel sets this token
# automatically when the store is linked.
BLOB_READ_WRITE_TOKEN=

# Required on Vercel for the daily cron job (/api/cron/refresh).
# Generate a random string and add it in Project Settings → Environment Variables.
CRON_SECRET=
